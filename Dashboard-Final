    {
        "id": "52a1b2bb857fed0b",
        "type": "function",
        "z": "37d810e1272bdb67",
        "name": "Daily & Hourly Accumulator",
        "func": "let currentHour = new Date().getHours();\nlet currentDay = new Date().getDate(); \n\n// Create a \"Logical Day\" that only changes at 06:00 AM\n// If it is 2:00 AM, it still counts as \"yesterday\"\nlet logicalDay = (currentHour < 6) ? currentDay - 1 : currentDay;\n\nlet amount = parseFloat(msg.payload) || 0;\n\n// 1. Fetch current tracking data to prevent spam/glitches\nlet tracking = flow.get('waterTracking');\nlet maxAllowed = Infinity; \n\nif (tracking && tracking.targetPerHour) {\n    maxAllowed = tracking.targetPerHour * 3; // 300% ceiling\n}\n\n// 2. Hourly Tracking\nlet hourlyData = flow.get('hourlyWater') || { hour: currentHour, total: 0 };\nif (hourlyData.hour !== currentHour) {\n    hourlyData = { hour: currentHour, total: 0 };\n}\n\n// Ignore data if it exceeds humanly possible drinking amounts (glitch filter)\nif (hourlyData.total + amount > maxAllowed) {\n    return null; \n}\n\nhourlyData.total += amount;\nflow.set('hourlyWater', hourlyData);\n\n// 3. Daily Tracking (Resets at 6:00 AM)\nlet dailyData = flow.get('dailyWater') || { logicalDay: logicalDay, total: 0 };\nif (dailyData.logicalDay !== logicalDay) {\n    dailyData = { logicalDay: logicalDay, total: 0 }; // Reset for the new day\n}\n\ndailyData.total += amount;\nflow.set('dailyWater', dailyData);\nflow.set('waterDrunkToday', dailyData.total);\n\n// 4. Send Outputs\nlet msg1 = { payload: dailyData.total }; \nlet msg2 = { payload: hourlyData.total, topic: \"ปริมาณ (ml)\" }; \nlet msg3 = { payload: dailyData.total, topic: \"ปริมาณ (ml)\" }; \n\nreturn [msg1, msg2, msg3];",
