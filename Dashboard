    {
        "id": "a32b2cd476768645",
        "type": "function",
        "z": "8aeacb57a28baf60",
        "name": "Daily & Hourly Accumulator",
        "func": "let today = new Date().toLocaleDateString();\nlet currentHour = new Date().getHours();\nlet amount = parseFloat(msg.payload) || 0;\n\n// 1. Fetch current tracking data to find the targetPerHour\nlet tracking = flow.get('waterTracking');\nlet maxAllowed = Infinity; \n\nif (tracking && tracking.targetPerHour) {\n    maxAllowed = tracking.targetPerHour * 3; // Set the 300% ceiling\n}\n\n// 2. Check Hourly Tracking\nlet hourlyData = flow.get('hourlyWater') || { hour: currentHour, total: 0 };\nif (hourlyData.hour !== currentHour) hourlyData = { hour: currentHour, total: 0 };\n\n// ถ้าค่าที่ส่งมา ทำให้ชั่วโมงนี้ดื่มเกิน 300% ให้ \"เพิกเฉย (Ignore) ข้อมูลชุดนี้ไปเลย\"\nif (hourlyData.total + amount > maxAllowed) {\n    return null; // หยุดการทำงานของโหนดนี้ทันที (ไม่บันทึก ไม่ส่งค่าต่อ)\n}\n\n// ถ้าไม่เกิน ให้บวกเพิ่มตามปกติ\nhourlyData.total += amount;\nflow.set('hourlyWater', hourlyData);\n\n// 3. Daily Tracking\nlet dailyData = flow.get('dailyWater') || { date: today, total: 0 };\nif (dailyData.date !== today) dailyData = { date: today, total: 0 };\n\ndailyData.total += amount;\nflow.set('dailyWater', dailyData);\nflow.set('waterDrunkToday', dailyData.total);\n\n// 4. Send Outputs\nlet msg1 = { payload: dailyData.total }; \nlet msg2 = { payload: hourlyData.total, topic: \"ปริมาณ (ml)\" }; \nlet msg3 = { payload: dailyData.total, topic: \"ปริมาณ (ml)\" }; \n\nreturn [msg1, msg2, msg3];",
