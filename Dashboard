    {
        "id": "0c802e210871f511",
        "type": "function",
        "z": "8aeacb57a28baf60",
        "name": "Main Logic Engine",
        "func": "let user = flow.get('userProfile') || {};\nlet temp = global.get('current_temp') || 25;\nlet drunk = flow.get('waterDrunkToday') || 0;\n\nif (!user.healthStatus) return null;\n\n// 1. Setup Time Range (ค่าเริ่มต้นคือ 06:00 - 22:00)\nlet startStr = user.startTime || \"06:00\";\nlet endStr = user.endTime || \"22:00\";\nlet startHour = parseInt(startStr.split(':')[0]) || 6;\nlet endHour = parseInt(endStr.split(':')[0]) || 22;\nlet currentHour = new Date().getHours();\n\nlet inTimeRange = false;\nif (startHour < endHour) {\n    inTimeRange = (currentHour >= startHour && currentHour < endHour);\n} else {\n    inTimeRange = (currentHour >= startHour || currentHour < endHour);\n}\n\nlet target = 0;\n// 2. กำหนดเป้าหมายรายวันตามโหมด\nif (user.healthStatus === 'normal') {\n    target = 2500;\n} else {\n    if (!user.weight || !user.diseases) return null;\n    let urine = parseFloat(user.urine) || 0;\n    target = user.weight * 35;\n    let ds = user.diseases;\n    \n    if (ds === 1) target = urine + 500;\n    else {\n        if (user.age > 55) target *= 0.90;\n        else if (user.age >= 30) target *= 0.95;\n\n        if (ds === 2) target *= 1.2;\n        else if (ds === 3) target += 750;\n        else if (ds === 4) target += 1000;\n    }\n    if (temp > 30) target *= 1.17;\n    else if (temp >= 20) target *= 1.05;\n}\n\n// 3. จัดการเป้าหมายรายชั่วโมงแบบยืดหยุ่น ตามชั่วโมงที่ตั้งค่าไว้\nlet totalActiveHours = (endHour > startHour) ? (endHour - startHour) : (24 - startHour + endHour);\nif (totalActiveHours <= 0) totalActiveHours = 16;\n\nlet tracking = flow.get('waterTracking') || {\n    lastHour: currentHour,\n    drunkAtLastHour: drunk,\n    targetPerHour: target / totalActiveHours,\n    expectedWaterSoFar: target / totalActiveHours\n};\n\n// รีเซ็ตการแทร็กข้อมูลใหม่เมื่อถึง Start Time ของวันใหม่\nif (currentHour === startHour && tracking.lastHour !== startHour) {\n    tracking = {\n        lastHour: currentHour,\n        drunkAtLastHour: 0,\n        targetPerHour: target / totalActiveHours,\n        expectedWaterSoFar: target / totalActiveHours\n    };\n}\n\nif (currentHour !== tracking.lastHour && inTimeRange) {\n    let waterDrankLastHour = drunk - tracking.drunkAtLastHour;\n    let acceptableMin = tracking.targetPerHour * 0.8;\n    let acceptableMax = tracking.targetPerHour * 1.2;\n\n    let remainingHours = endHour - currentHour;\n    if (endHour <= startHour && currentHour >= startHour) {\n        remainingHours = (24 - currentHour) + endHour;\n    } else if (endHour <= startHour && currentHour < endHour) {\n        remainingHours = endHour - currentHour;\n    }\n    if (remainingHours < 1) remainingHours = 1;\n\n    if (waterDrankLastHour < acceptableMin || waterDrankLastHour > acceptableMax) {\n        let waterLeft = target - drunk;\n        tracking.targetPerHour = waterLeft / remainingHours;\n        if (tracking.targetPerHour < 0) tracking.targetPerHour = 0;\n    }\n\n    tracking.expectedWaterSoFar += tracking.targetPerHour;\n    tracking.drunkAtLastHour = drunk;\n    tracking.lastHour = currentHour;\n\n    flow.set('waterTracking', tracking);\n}\n\nlet percent = ((drunk / target) * 100).toFixed(1);\n\n// 4. แจ้งเตือน (Mute/Snooze Logic)\nlet alertData = flow.get('alertData') || { lastAlertHour: -1, waterAtAlert: 0 };\nlet alert = false;\n\n// ระบบเตือนจะทำงานเมื่ออยู่ในเวลาทำการ (inTimeRange) เท่านั้น!\nlet isBehind = (temp > 32 && drunk < tracking.expectedWaterSoFar && inTimeRange);\nlet sufficientAmountMin = tracking.targetPerHour * 0.8; \n\nif (isBehind) {\n    if (alertData.lastAlertHour !== currentHour) {\n        alert = true;\n        alertData.lastAlertHour = currentHour;\n        alertData.waterAtAlert = drunk;\n    } else {\n        let waterDrankSinceAlert = drunk - alertData.waterAtAlert;\n        if (waterDrankSinceAlert >= sufficientAmountMin) {\n            alert = false; \n        } else {\n            alert = true;\n        }\n    }\n} else {\n    alert = false;\n    if (drunk >= tracking.expectedWaterSoFar) {\n        alertData.lastAlertHour = -1;\n    }\n}\n\nflow.set('alertData', alertData);\n\nmsg.payload = (target / 1000).toFixed(2);\nmsg.percent = percent;\nmsg.alert = alert;\nreturn msg;",
