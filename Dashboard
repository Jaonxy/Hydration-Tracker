    {
        "id": "a5950b279ff831f2",
        "type": "function",
        "z": "a2d07945efe475ee",
        "name": "Daily Accumulator",
        "func": "let today = new Date().toLocaleDateString();\nlet data = flow.get('dailyWater') || { date: today, total: 0 };\nif (data.date !== today) data = { date: today, total: 0 };\ndata.total += parseFloat(msg.payload);\nflow.set('dailyWater', data);\nflow.set('waterDrunkToday', data.total);\nmsg.payload = data.total;\nreturn msg;",
        "outputs": 1,
        "x": 330,
        "y": 340,
        "wires": [
            [
                "d542a1a93beb6a8e"
            ]
        ]
    },
    {
        "id": "d542a1a93beb6a8e",
        "type": "function",
        "z": "a2d07945efe475ee",
        "name": "Main Logic Engine",
        "func": "let user = flow.get('userProfile') || {};\nlet temp = global.get('current_temp') || 25;\nlet drunk = flow.get('waterDrunkToday') || 0;\nif (!user.weight || !user.diseases) return null;\n\nlet urine = parseFloat(user.urine) || 0;\nlet target = user.weight * 35;\nlet ds = user.diseases;\n\n// 1. คำนวณตามเงื่อนไขโรคพิเศษ\nif (ds === 1) target = urine + 500;\nelse {\n    if (user.age > 55) target *= 0.90;\n    else if (user.age >= 30) target *= 0.95;\n    \n    if (ds === 2) target *= 1.2;\n    else if (ds === 3) target += 750;\n    else if (ds === 4) target += 1000;\n}\n\n// 2. ปรับตามอุณหภูมิ\nif (temp > 30) target *= 1.17;\nelse if (temp >= 20) target *= 1.05;\n\nlet percent = ((drunk / target) * 100).toFixed(1);\nlet alert = (temp > 32 && percent < 30);\n\nmsg.payload = (target / 1000).toFixed(2);\nmsg.percent = percent;\nmsg.alert = alert;\nreturn msg;",
        "outputs": 1,
        "x": 580,
        "y": 280,
        "wires": [
            [
                "2ad7e24545eddf33",
                "2aa86bd03872d1e5",
                "132002d87f969ae7"
            ]
        ]
